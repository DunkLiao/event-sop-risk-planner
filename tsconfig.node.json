{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true
  },
  "include": [
    "vite.config.ts",
    "electron",
    "src/services/**/*.ts",
    "src/store/settingsStore.ts",
    "src/templates/**/*.ts",
    "src/types/**/*.ts",
    "src/utils/**/*.ts"
  ]
}
